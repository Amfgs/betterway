{
  "expo": {
    "name": "Better Way",
    "slug": "betterway",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./src/assets/brand/betterway-app-icon.png",
    "scheme": "betterway",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.amfgs.betterway"
    },
    "android": {
      "package": "com.amfgs.betterway",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/brand/betterway-adaptive-icon.png",
        "backgroundColor": "#eff7f3"
      }
    },
    "extra": {
      "apiUrl": "https://api.betterway.com.br/api"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "A Better Way usa o Face ID somente para desbloquear seus dados financeiros neste aparelho."
        }
      ]
    ]
  }
}
